{
	"name": "claude-overwrite-features",
	"displayName": "Claude Code — Overwrite Features",
	"description": "Patches the Claude Code extension to fix auto-include file, compact attachments, and compact confirmation behaviors.",
	"version": "0.6.4",
	"publisher": "Blake-C",
	"license": "MIT",
	"engines": {
		"vscode": "^1.94.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "claudeOverwrite.applyPatches",
				"title": "Claude Code Patch: Re-apply Feature Patches"
			},
			{
				"command": "claudeOverwrite.revertPatches",
				"title": "Claude Code Patch: Revert Feature Patches"
			},
			{
				"command": "claudeOverwrite.previewDialog",
				"title": "Claude Code Patch: Preview Compact Confirm Dialog"
			},
			{
				"command": "claudeOverwrite.ollamaStatus",
				"title": "Claude Code Patch: Check Ollama Status"
			},
			{
				"command": "claudeOverwrite.ollamaRecommend",
				"title": "Claude Code Patch: Recommend Ollama Model"
			},
{
				"command": "claudeOverwrite.configureOllama",
				"title": "Claude Code Patch: Use Local Ollama Model"
			},
			{
				"command": "claudeOverwrite.revertOllama",
				"title": "Claude Code Patch: Revert to Anthropic API (Ollama)"
			}
		]
	},
	"scripts": {
		"compile": "webpack --mode development",
		"watch": "webpack --mode development --watch",
		"package": "webpack --mode production",
		"lint": "eslint src",
		"check-patches": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-patches.ts",
		"watcher:install": "bash scripts/install-watcher.sh",
		"watcher:uninstall": "bash scripts/uninstall-watcher.sh",
		"watcher:run": "bash scripts/on-claude-update.sh"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.94.0",
		"ts-loader": "^9.5.0",
		"typescript": "^5.4.0",
		"webpack": "^5.91.0",
		"webpack-cli": "^5.1.4"
	}
}
